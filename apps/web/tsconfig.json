{
  "extends": "@repo/config-typescript/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@repo/shared-schemas": ["../../packages/shared-schemas/src/index.ts"],
      "@repo/shared-schemas/*": ["../../packages/shared-schemas/src/*"]
