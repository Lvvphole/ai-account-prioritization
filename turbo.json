{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalEnv": [
    "NODE_ENV",
    "EVAL_JUDGE_ENABLED",
    "ANTHROPIC_API_KEY",
    "EVAL_JUDGE_MODEL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "dependsOn": [],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:evals": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:judge": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "generate": {
      "outputs": ["generated/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
