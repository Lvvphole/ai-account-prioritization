{
  "$ref": "#/definitions/VerificationResult",
  "definitions": {
    "VerificationResult": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "pending"
          ]
        },
        "schemaValid": {
          "type": "boolean"
        },
        "guardrailsPassed": {
          "type": "boolean"
        },
        "sourceSignalsVerified": {
          "type": "boolean"
        },
        "permissionGranted": {
          "type": "boolean"
        },
        "failedGates": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "checkedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "status",
        "schemaValid",
        "guardrailsPassed",
        "sourceSignalsVerified",
        "permissionGranted",
        "checkedAt"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
