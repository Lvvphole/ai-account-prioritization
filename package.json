{
  "name": "ai-account-prioritization",
  "version": "1.0.0",
  "private": true,
  "description": "AI Account Prioritization Agent for B2B Sales Teams — deterministic, eval-gated, human-in-the-loop monorepo.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:evals": "turbo run test:evals",
    "test:judge": "turbo run test:judge",
    "generate:schemas": "pnpm --filter @repo/shared-schemas generate",
    "build:api-python": "pnpm --filter api-python build",
    "supabase:types": "bash scripts/generate-supabase-types.sh",
    "db:lint": "supabase db lint",
    "check:no-prisma": "bash scripts/check-no-prisma.sh",
    "docker:config": "docker compose -f infra/compose.yaml config",
    "docker:build": "docker compose -f infra/compose.yaml build",
    "verify:security": "bash scripts/verify-security.sh",
    "verify:observability": "bash scripts/verify-observability.sh",
    "verify:production": "bash scripts/verify-production-contract.sh",
    "dev": "turbo run dev",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
