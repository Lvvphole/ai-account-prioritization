# ---------------------------------------------------------------------------
# AI Account Prioritization Agent — environment template
# Copy to .env and fill in. NEVER commit a real .env or real secrets.
# The deterministic runtime path requires NONE of these to be set; absent
# integrations degrade to in-memory/mock so the core loop stays runnable.
# ---------------------------------------------------------------------------

# --- Supabase (database, auth, RLS) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# --- LLM (generation only; never ranking) ---
AI_MODEL=
OPENAI_API_KEY=

# --- Sentry (application reliability; no secrets/unredacted PII) ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Langfuse (LLM + eval observability; not a runtime ranking authority) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=

# --- CRM + evaluation toggles ---
CRM_PROVIDER=mock
EVAL_JUDGE_ENABLED=false
