# ---------------------------------------------------------------------------
# AI Account Prioritization Agent — environment template
# Copy to .env and fill in. NEVER commit a real .env.
# The deterministic runtime path does NOT require any of these to be set;
# they configure optional integrations and the async judge gate only.
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=development

# --- Async LLM-as-a-judge (evaluation path only; never in runtime) ---
# When true, the judge eval becomes deployment-blocking in CI.
EVAL_JUDGE_ENABLED=false
# Model used by the judge when an API key is present. Falls back to a
# deterministic heuristic judge when no key/network is available.
EVAL_JUDGE_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=

# --- CRM integration (optional; runtime reads via shared-tools/crm) ---
CRM_BASE_URL=
CRM_API_KEY=

# --- Database (optional; repository defaults to in-memory) ---
DATABASE_URL=

# --- Python support service ---
API_PYTHON_HOST=0.0.0.0
API_PYTHON_PORT=8000

# --- Human-in-the-loop approval ---
# When true, customer-facing sends and CRM write-backs require explicit
# approval before publish. Hard-defaulted ON; do not disable in production.
REQUIRE_HUMAN_APPROVAL=true
