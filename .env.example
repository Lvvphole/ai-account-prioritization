# ---------------------------------------------------------------------------
# AI Account Prioritization Agent — environment template
# Copy to .env and fill in. NEVER commit a real .env or real secrets.
# The deterministic runtime path requires NONE of these to be set; absent
# integrations degrade to in-memory/mock so the core loop stays runnable.
# ---------------------------------------------------------------------------

# --- Supabase (database, auth, RLS) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# --- LLM judge (async eval only; never ranking) ---
# Without ANTHROPIC_API_KEY the judge stays on the deterministic heuristic.
ANTHROPIC_API_KEY=
EVAL_JUDGE_MODEL=

# --- Sentry (planned; not yet read by code) — application reliability ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Langfuse (planned; not yet read by code) — LLM + eval observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=

# --- CRM source (absent => in-memory mock) ---
CRM_BASE_URL=
CRM_API_KEY=

# --- Runtime toggles ---
EVAL_JUDGE_ENABLED=false
REQUIRE_HUMAN_APPROVAL=true
